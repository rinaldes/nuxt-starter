{
  "name": "rindu-starter",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "check": "pnpm lint && pnpm test && pnpm build",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "lint:fix": "eslint . --fix && prettier --write --list-different .",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^2.3.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "0.7.3",
    "@nuxt/image": "1.8.1",
    "@nuxt/test-utils": "^3.15.1",
    "@nuxt/ui": "^2.20.0",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "12.0.0",
    "@pinia/nuxt": "^0.9.0",
    "@sentry/nuxt": "8.42.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "nuxt": "^3.14.1592",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vue": "latest"
  },
  "pnpm": {
    "overrides": {
      "nitropack": "~2.9.7",
      "@vercel/nft": "^0.27.4"
    }
  }
}
