{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    /* Type Safety */
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/app/*": ["src/app/*"],
      "@/feature/*": ["src/feature/*"],
      "@/shared/*": ["src/shared/*"],
      "#imports": [".nuxt/imports.d.ts"]
    }
  }
}
